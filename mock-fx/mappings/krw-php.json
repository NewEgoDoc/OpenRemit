{
  "request": {
    "method": "GET",
    "urlPath": "/rates",
    "queryParameters": {
      "from": { "equalTo": "KRW" },
      "to":   { "equalTo": "PHP" }
    }
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
